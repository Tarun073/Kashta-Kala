<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme using Material 3 -->
    <style name="Theme.KashtaKala" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryLight</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/colorPrimaryLight</item>
        <item name="colorOnSecondaryContainer">@color/white</item>

        <!-- Tertiary brand color -->
        <item name="colorTertiary">@color/colorAccent</item>
        <item name="colorOnTertiary">@color/white</item>

        <!-- Error color -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <!-- Background and Surface colors -->
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorOnBackground">@color/black</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorSurfaceVariant">@color/colorBackground</item>
        <item name="colorOnSurfaceVariant">@color/colorTextSecondary</item>
        <item name="colorOutline">@color/colorBorder</item>

        <!-- Status bar and Navigation bar -->
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <item name="android:navigationBarColor">@color/colorSurface</item>
    </style>
</resources>